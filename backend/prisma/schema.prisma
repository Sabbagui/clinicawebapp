// This is your Prisma schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DOCTOR
  NURSE
  RECEPTIONIST
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CHECKED_IN
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum AppointmentType {
  FIRST_VISIT
  FOLLOW_UP
  EXAM
  PROCEDURE
  URGENT
}

enum MedicalRecordStatus {
  DRAFT
  FINAL
}

enum PaymentMethod {
  PIX
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

enum PrescriptionType {
  SIMPLES
  CONTROLE_ESPECIAL_C1
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(RECEPTIONIST)
  isActive  Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Doctor profile
  crm           String?
  crmUf         String?
  clinicName    String?
  clinicAddress String?
  clinicPhone   String?

  doctorAppointments   Appointment[]        @relation("DoctorAppointments")
  createdAppointments  Appointment[]        @relation("CreatedAppointments")
  doctorSchedule       DoctorSchedule[]     @relation("DoctorSchedule")
  doctorBlocked        DoctorBlockedSlot[]  @relation("DoctorBlocked")
  medicalRecords       MedicalRecord[]
  finalizedRecords     MedicalRecord[]      @relation("FinalizedRecords")
  createdExpenses      Expense[]            @relation("CreatedExpenses")
  createdIncomes       Income[]             @relation("CreatedIncomes")
  certificate          DoctorCertificate?
  issuedPrescriptions  IssuedPrescription[] @relation("DoctorPrescriptions")

  @@map("users")
}

model Patient {
  id        String   @id @default(uuid())
  name      String
  cpf       String   @unique
  birthDate DateTime
  phone     String
  whatsapp  String?
  email     String?

  // Address
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String

  // Emergency Contact
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?

  // LGPD consent
  lgpdConsentGiven Boolean   @default(false)
  lgpdConsentDate  DateTime?
  lgpdConsentText  String?

  // Soft delete
  isActive  Boolean   @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments         Appointment[]
  medicalRecords       MedicalRecord[]
  issuedPrescriptions  IssuedPrescription[]

  @@map("patients")
}

model Appointment {
  id            String            @id @default(uuid())
  patientId     String
  patient       Patient           @relation(fields: [patientId], references: [id])
  doctorId      String
  doctor        User              @relation("DoctorAppointments", fields: [doctorId], references: [id])
  createdById   String?
  createdBy     User?             @relation("CreatedAppointments", fields: [createdById], references: [id])
  date          DateTime?         @db.Date
  startTime     DateTime?         @db.Time()
  endTime       DateTime?         @db.Time()
  scheduledDate DateTime
  duration      Int               @default(30) // in minutes
  status        AppointmentStatus @default(SCHEDULED)
  type          AppointmentType
  notes         String?
  cancelReason  String?
  reminderSent  Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  medicalRecord MedicalRecord?
  payment       Payment?

  @@index([doctorId, scheduledDate])
  @@index([patientId, scheduledDate])
  @@index([status, scheduledDate])
  @@unique([doctorId, date, startTime], name: "unique_doctor_slot")
  @@index([patientId])
  @@index([doctorId, date])
  @@index([date, status])
  @@index([reminderSent, scheduledDate])
  @@map("appointments")
}

model DoctorSchedule {
  id          String   @id @default(uuid())
  doctorId    String
  doctor      User     @relation("DoctorSchedule", fields: [doctorId], references: [id])
  dayOfWeek   Int
  startTime   String
  endTime     String
  slotMinutes Int      @default(30)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([doctorId, dayOfWeek])
}

model DoctorBlockedSlot {
  id        String   @id @default(uuid())
  doctorId  String
  doctor    User     @relation("DoctorBlocked", fields: [doctorId], references: [id])
  date      DateTime @db.Date
  startTime DateTime @db.Time()
  endTime   DateTime @db.Time()
  reason    String?
  createdAt DateTime @default(now())

  @@index([doctorId, date])
}

model MedicalRecord {
  id            String              @id @default(uuid())
  patientId     String
  patient       Patient             @relation(fields: [patientId], references: [id])
  appointmentId String              @unique
  appointment   Appointment         @relation(fields: [appointmentId], references: [id])
  doctorId      String
  doctor        User                @relation(fields: [doctorId], references: [id])
  date          DateTime            @default(now())

  // SOAP Notes
  subjective    String              @default("")
  objective     String              @default("")
  assessment    String              @default("")
  plan          String              @default("")

  // Clinical extras
  cid10         String?
  prescriptions Json?

  // Status
  status        MedicalRecordStatus @default(DRAFT)
  finalizedAt   DateTime?
  finalizedById String?
  finalizedBy   User?               @relation("FinalizedRecords", fields: [finalizedById], references: [id])

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  issuedPrescriptions IssuedPrescription[]

  @@map("medical_records")
}

model Payment {
  id            String        @id @default(uuid())
  appointmentId String        @unique
  appointment   Appointment   @relation(fields: [appointmentId], references: [id])
  amount        Int
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  paidAt        DateTime?
  refundedAt    DateTime?
  notes         String?
  receiptPath   String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@map("payments")
}

model ExpenseCategory {
  id        String    @id @default(uuid())
  name      String    @unique
  label     String
  isDefault Boolean   @default(false)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  expenses  Expense[]

  @@map("expense_categories")
}

model Expense {
  id          String          @id @default(uuid())
  description String
  amount      Int
  categoryId  String
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  date        DateTime        @db.Date
  notes       String?
  receiptPath String?
  createdById String
  createdBy   User            @relation("CreatedExpenses", fields: [createdById], references: [id])
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([date])
  @@index([categoryId, date])
  @@map("expenses")
}

model IncomeCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  label     String
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  incomes   Income[]

  @@map("income_categories")
}

model Income {
  id          String         @id @default(uuid())
  description String
  amount      Int
  categoryId  String
  category    IncomeCategory @relation(fields: [categoryId], references: [id])
  date        DateTime       @db.Date
  notes       String?
  receiptPath String?
  createdById String
  createdBy   User           @relation("CreatedIncomes", fields: [createdById], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([date])
  @@index([categoryId, date])
  @@map("incomes")
}

model DoctorCertificate {
  id          String    @id @default(uuid())
  doctorId    String    @unique
  doctor      User      @relation(fields: [doctorId], references: [id])
  storedPath  String
  iv          String
  authTag     String
  encPassword String
  subjectCN   String?
  issuerCN    String?
  notBefore   DateTime?
  notAfter    DateTime?
  uploadedAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("doctor_certificates")
}

model IssuedPrescription {
  id              String           @id @default(uuid())
  medicalRecordId String
  medicalRecord   MedicalRecord    @relation(fields: [medicalRecordId], references: [id])
  doctorId        String
  doctor          User             @relation("DoctorPrescriptions", fields: [doctorId], references: [id])
  patientId       String
  patient         Patient          @relation(fields: [patientId], references: [id])
  type            PrescriptionType
  pdfPath         String
  authHash        String
  isSigned        Boolean          @default(false)
  issuedAt        DateTime         @default(now())
  expiresAt       DateTime?

  @@index([medicalRecordId])
  @@index([doctorId, issuedAt])
  @@map("issued_prescriptions")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  actorRole   String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId, createdAt])
  @@index([actorUserId, createdAt])
  @@map("audit_logs")
}
